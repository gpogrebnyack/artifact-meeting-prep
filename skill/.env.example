# API ключи для навыка artifact-meeting-prep
# Скопируй этот файл в ~/.claude/skills/artifact-meeting-prep/.env и заполни своими ключами.

# Apify API token (https://console.apify.com/account/integrations)
# Нужен для: YouTube поиск/транскрипция, Instagram, Facebook, LinkedIn, Website Content Crawler
APIFY_TOKEN=

# VK API сервисный токен (https://dev.vk.com → Мои приложения → Настройки)
# Нужен для: VK стена, сообщества, профили пользователей
VK_SERVICE_TOKEN=

# VK user token (опционально, живёт 24 часа)
# Нужен для: VK video.search
# Получить: https://oauth.vk.com/authorize?client_id=APP_ID&display=page&redirect_uri=https://oauth.vk.com/blank.html&scope=video&response_type=token&v=5.199
VK_USER_TOKEN=
